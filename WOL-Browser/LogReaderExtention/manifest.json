{
    "name": "Log Reader3",
    "description": "Sends logs of user actions to the server for analysis",
    "version": "2.0",
    "manifest_version": 3,

	"content_scripts":[
        {
            "matches":["*://*/*"],

            "js":["inject.js"],
            "all_frames": true 
        }
    ],

    "permissions": [
        "activeTab",
        "alarms",
        "background",
        "bookmarks",
        "browsingData",
        "clipboardRead",
        "clipboardWrite",
        "contentSettings",
        "contextMenus",
        "cookies",
        "debugger",
        "declarativeContent",
        "desktopCapture",
        "downloads",
        "fontSettings",
        "gcm",
        "geolocation",
        "tabs",
        "webNavigation"
    ],

    "host_permissions": [
		"https://campus-3.shinshu-u.ac.jp/*",
		"https://spica.gakumu.tuat.ac.jp/*",
		"https://www.rakuten.co.jp/*",
		"https://www.facebook.com/*",
		"https://www.amazon.co.jp/*",
		"https://anet.akita-u.ac.jp/",
		"https://eduweb.sta.kanazawa-u.ac.jp/",
		"https://basket.step.rakuten.co.jp/*",
		"https://www.dnp.co.jp/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:5000/*",
		"https://160.252.130.85:443/*"
    ],

    "action": {
        "default_title": "Send user activity logs",
        "default_icon": "send_16x16.png"
    }
}
